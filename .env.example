# API Configuration (Binance Futures)
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here
# If fapi.binance.com is blocked or slow, you can try:
# BINANCE_BASE_URL=https://fapi.binance.co

# Telegram Configuration (use a SEPARATE bot token from the scalp bot!)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
# If Telegram is blocked in your region:
# TELEGRAM_BASE_URL=https://api.telegram.org

# Bot Settings
LOG_LEVEL=info
# HTF bot scans every 5 minutes (1h candles don't need sub-minute scans)
SCAN_INTERVAL_SECONDS=300
UNIVERSE_REFRESH_MINUTES=120
TOP_N_SYMBOLS=30

# Signal Settings
MIN_SIGNAL_SCORE=75
MIN_PROFIT_LEVERAGED=2.0
# ^ Minimum R:R ratio — higher on HTF because we want bigger moves
TARGET_RISK_PERCENT=1.0
# Longer cooldowns for HTF (hours not minutes)
COOLDOWN_MINUTES=120
MAX_ALERTS_PER_SYMBOL_PER_DAY=3
MAX_ALERTS_GLOBAL_PER_DAY=30
